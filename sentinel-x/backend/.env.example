# SENTINEL-X V2 — Environment Configuration

# Required: Anthropic API key for Claude analysis
ANTHROPIC_API_KEY=sk-ant-...

# Database (defaults to local SQLite; swap for PostgreSQL in production)
DATABASE_URL=sqlite+aiosqlite:///./sentinel_x.db
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost/sentinel_x

# Scraper settings
REALTIME_POLL_INTERVAL_SECONDS=60
HISTORICAL_WINDOW_DAYS=180
MAX_CONCURRENT_SCRAPERS=5

# Claude model (default: claude-sonnet-4-6)
CLAUDE_MODEL=claude-sonnet-4-6

# Frontend origin (for CORS)
# Add your production domain here when deploying
